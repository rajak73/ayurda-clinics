# =========================================================================
# AYURDA CLINICS — PRODUCTION ENVIRONMENT CONFIGURATION TEMPLATE
# =========================================================================

# -------------------------------------------------------------------------
# FRONTEND CONFIGURATION (Render Static Site Environment)
# -------------------------------------------------------------------------
VITE_API_URL=https://your-ayurda-backend.onrender.com/api
VITE_BACKEND_URL=https://your-ayurda-backend.onrender.com

# -------------------------------------------------------------------------
# BACKEND CONFIGURATION (Render Web Service Environment)
# -------------------------------------------------------------------------
PORT=5001
JWT_SECRET=your_production_jwt_secret_key_change_me

# Database Configuration (Railway MySQL)
# Note: Railway automatically injects MYSQLHOST, MYSQLPORT, MYSQLUSER, MYSQLPASSWORD, and MYSQLDATABASE.
# If these are defined, the backend will auto-detect them. Otherwise, configure below:
DB_HOST=your-railway-db-host.railway.internal
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your-railway-db-password
DB_NAME=railway

# Email SMTP Settings (for appointment and registration notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-smtp-email@gmail.com
SMTP_PASS=your-smtp-gmail-app-password

# Twilio WhatsApp Notification Settings (Optional)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Clinic Profile Configuration
ADMIN_EMAIL=your-admin-inquiries-email@gmail.com
CLINIC_NAME=Ayurda Clinics
CLINIC_PHONE=+91-98765-43210
FRONTEND_URL=https://your-ayurda-frontend.onrender.com
